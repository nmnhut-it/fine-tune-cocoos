{
    "name": "context7-local",
    "version": "1.0.0",
    "description": "Local Context7-compatible MCP server",
    "type": "module",
    "main": "build/index.js",
    "scripts": {
        "build": "tsc",
        "dev": "tsx src/index.ts",
        "index": "tsx scripts/index-docs.ts",
        "test:search": "tsx scripts/test-search.ts",
        "test:sampleSearch": "tsx scripts/test-search.ts --query \"hướng dẫn dùng cc.SpriteBatchNode\" --max 1",
        "mcp:setup": "tsx scripts/setup-mcp.ts",
        "mcp:remove": "tsx scripts/setup-mcp.ts -r",
        "full-setup": "npm i && npm run build && npm run index && npm run mcp:setup"
    },
    "dependencies": {
        "@huggingface/transformers": "^3.4.0",
        "@modelcontextprotocol/sdk": "^1.10.1",
        "better-sqlite3": "^12.6.2",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.12",
        "@types/node": "^22.13.10",
        "tsx": "^4.19.3",
        "typescript": "^5.8.2"
    }
}
